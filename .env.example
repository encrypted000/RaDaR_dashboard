# Copy this file to .env and fill in the values before running with Docker.
# .env is git-ignored — never commit it.

# PostgreSQL password for the radar_ro read-only user
RADAR_DB_PASS=

# Path to your SSH private key on the host machine
# (will be mounted read-only into the container)
SSH_KEY_FILE=~/.ssh/id_rsa

# SSH username for db.radar.nhs.uk (default: bidhanp)
SSH_USER=bidhanp
